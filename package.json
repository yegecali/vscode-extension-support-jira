{
  "name": "jira-ticket-classifier",
  "displayName": "Jira Ticket Classifier",
  "description": "Agente LLM que clasifica tickets Jira, valida datos y genera URLs de monitoreo",
  "version": "0.1.0",
  "publisher": "your-publisher",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:ticketPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jira-classifier",
          "title": "Jira Classifier",
          "icon": "$(bug)"
        }
      ]
    },
    "views": {
      "jira-classifier": [
        {
          "id": "ticketPanel",
          "name": "Tickets",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "jiraClassifier.startSupport",
        "title": "Iniciar Soporte"
      },
      {
        "command": "jiraClassifier.stopSupport",
        "title": "Detener Soporte"
      },
      {
        "command": "jiraClassifier.refresh",
        "title": "Refrescar tickets"
      },
      {
        "command": "jiraClassifier.openSettings",
        "title": "Configurar prompts"
      },
      {
        "command": "jiraClassifier.clearCache",
        "title": "Limpiar cache y reanalizar"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jiraClassifier.refresh",
          "group": "navigation",
          "when": "view == ticketPanel"
        },
        {
          "command": "jiraClassifier.openSettings",
          "group": "navigation",
          "when": "view == ticketPanel"
        },
        {
          "command": "jiraClassifier.clearCache",
          "group": "navigation",
          "when": "view == ticketPanel"
        }
      ]
    },
    "configuration": {
      "title": "Jira Classifier",
      "properties": {
        "jiraClassifier.jiraUrl": {
          "type": "string",
          "default": "",
          "description": "URL base de Jira (ej: https://myco.atlassian.net)"
        },
        "jiraClassifier.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "Email de la cuenta Jira"
        },
        "jiraClassifier.jiraProject": {
          "type": "string",
          "default": "",
          "description": "Clave del proyecto (ej: BANK)"
        },
        "jiraClassifier.jiraJql": {
          "type": "string",
          "default": "project = BANK AND status != Closed AND updated >= -7d ORDER BY updated DESC",
          "description": "JQL para filtrar tickets"
        },
        "jiraClassifier.grafanaBaseUrl": {
          "type": "string",
          "default": "",
          "description": "URL base de Grafana"
        },
        "jiraClassifier.kibanaBaseUrl": {
          "type": "string",
          "default": "",
          "description": "URL base de Kibana"
        },
        "jiraClassifier.pollingIntervalMinutes": {
          "type": "number",
          "default": 10,
          "description": "Intervalo de polling en minutos"
        },
        "jiraClassifier.scoreThreshold": {
          "type": "number",
          "default": 0.7,
          "description": "Umbral de score (0.0 - 1.0). En modo Legacy: relevancia de keywords. En modo Markdown+LLM: se multiplica por 100 (ej: 0.7 = 70/100 LLM score). Consulta README.md > Flujos de Clasificación"
        },
        "jiraClassifier.classifierPrompts": {
          "type": "array",
          "default": [
            {
              "id": "auth-error",
              "label": "Error autenticación tarjeta",
              "classification": "AUTH_ERROR",
              "keywords": [
                "autenticacion",
                "tarjeta",
                "pin",
                "token",
                "rechazo",
                "fallida"
              ],
              "requiredFields": [
                "request_id",
                "card_last4",
                "timestamp"
              ],
              "grafanaDashboard": "/d/auth-errors",
              "kibanaDashboard": "/app/discover#/?_a=(query:(match_phrase:(type:authentication)))",
              "promptTemplate": "Eres un agente de soporte bancario especializado en errores de autenticación. Analiza el ticket y determina:\n1. Clasificación: ¿es un error de PIN? ¿Token expirado? ¿Datos insuficientes?\n2. Campos faltantes: request_id, card_last4, timestamp\n3. Próximos pasos: verificar logs, contactar customer, escalar a seguridad\nSé conciso y directo."
            },
            {
              "id": "delayed-transfer",
              "label": "Transferencia demorada",
              "classification": "DELAYED_TRANSFER",
              "keywords": [
                "transferencia",
                "demora",
                "no llego",
                "pendiente",
                "stuck",
                "retraso"
              ],
              "requiredFields": [
                "transaction_id",
                "source_account",
                "amount"
              ],
              "grafanaDashboard": "/d/transfers",
              "kibanaDashboard": "/app/discover#/?_a=(query:(match_phrase:(type:transfer)))",
              "promptTemplate": "Eres un especialista en procesamiento de transferencias. Analiza el ticket:\n1. Clasificación: ¿es una transferencia interna o internacional? ¿Tiempo esperado vs actual?\n2. Campos necesarios: transaction_id, source_account, amount, destination_account\n3. Pasos de debugging: revisar cola de procesamiento, verificar cortes de red\nSé analítico y estructurado."
            },
            {
              "id": "blocked-card",
              "label": "Tarjeta bloqueada",
              "classification": "BLOCKED_CARD",
              "keywords": [
                "bloqueada",
                "blocked",
                "rechazada",
                "no funciona",
                "desactivada",
                "suspendida"
              ],
              "requiredFields": [
                "card_last4",
                "customer_id"
              ],
              "grafanaDashboard": "/d/cards",
              "kibanaDashboard": "/app/discover#/?_a=(query:(match_phrase:(type:card)))",
              "promptTemplate": "Eres un agente de seguridad de tarjetas. Analiza el ticket:\n1. Clasificación: ¿bloqueo por fraude? ¿Vencimiento? ¿Límite alcanzado?\n2. Datos críticos: card_last4, customer_id, fecha de vencimiento\n3. Acciones: desbloquear si es falsa alarma, emitir nueva tarjeta, investigar fraude\nPrioritiza seguridad del cliente."
            }
          ],
          "description": "(Legacy) Array de clasificadores con prompts y campos requeridos. Solo se usa cuando promptsDirectory está vacío. Consulta README.md > Flujos de Clasificación",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "classification": {
                "type": "string"
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "requiredFields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "grafanaDashboard": {
                "type": "string"
              },
              "kibanaDashboard": {
                "type": "string"
              },
              "promptTemplate": {
                "type": "string"
              }
            }
          }
        },
        "jiraClassifier.promptsDirectory": {
          "type": "string",
          "default": "",
          "description": "(Nuevo) Ruta al directorio con archivos .md de diagnóstico. Habilita modo Markdown + LLM Scoring (paralelo). Si se configura, reemplaza classifierPrompts. Consulta README.md > Flujos de Clasificación para el formato de archivos. Ejemplo: /Users/me/jira-prompts"
        },
        "jiraClassifier.promptsDocumentation": {
          "type": "string",
          "default": "",
          "description": "(Nuevo) Ruta a un archivo de documentación del proyecto. El contenido será incluido en el contexto del LLM para análisis más precisos. Ejemplo: /Users/me/project-docs.md"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
